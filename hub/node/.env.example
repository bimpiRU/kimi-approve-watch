# Jarvis Hub — конфигурация. Скопируй в .env и заполни. .env НЕ коммитится.

# Порт и адрес прослушивания (0.0.0.0 — доступ снаружи, для сервера)
PORT=8787
HOST=127.0.0.1

# OAuth GitHub: https://github.com/settings/developers → OAuth Apps
# callback: http://<host>:<port>/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# OAuth Google: https://console.cloud.google.com/apis/credentials → OAuth client ID (Web)
# redirect URI: http://<host>:<port>/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Кому разрешён вход: логины GitHub и/или Google-почты, через запятую
AUTH_ALLOW=bimpiRU

# Telegram-бот (управление и уведомления с телефона): токен от @BotFather
TELEGRAM_BOT_TOKEN=
# id разрешённого чата; узнать: напиши боту /start — id появится в консоли сервера
TELEGRAM_CHAT_ID=
